# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cryptocompare?schema=public"

# Upstash Redis (HTTP-based, for caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Admin Protection (leave empty to disable in development)
ADMIN_PASSWORD=""

# Cron Secret (shared between Next.js and Cloudflare Worker)
CRON_SECRET=""

# Blog Generator Service (Project 1)
# URL of the standalone blog generator service running on Hetzner
BLOG_GENERATOR_URL="http://localhost:4100"
# Shared secret for authenticating trigger requests to the blog generator
BLOG_GENERATOR_SECRET=""

# Blog Source (read-only integration)
# Base URL of the blog generator API for fetching published posts
BLOG_SOURCE_URL="http://localhost:4100"
