{
  "name": "cryptocompare-blog-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight AI blog generation service for CryptoCompare AI",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "generate": "node dist/cli.js",
    "dev": "ts-node src/api/server.ts",
    "dev:generate": "ts-node src/cli.ts",
    "dev:list": "ts-node src/cli.ts list",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
