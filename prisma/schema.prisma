generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Exchange ───────────────────────────────────────────────────────────────────

model Exchange {
  id                   String            @id @default(cuid())
  slug                 String            @unique
  name                 String
  logoUrl              String?           @map("logo_url")
  affiliateUrl         String?           @map("affiliate_url")
  score                Float             @default(0)
  foundedYear          Int?              @map("founded_year")
  headquarters         String?
  description          String?
  supportedCoinsCount  Int               @default(0) @map("supported_coins_count")
  kycRequired          Boolean           @default(false) @map("kyc_required")
  spotAvailable        Boolean           @default(true) @map("spot_available")
  futuresAvailable     Boolean           @default(false) @map("futures_available")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  fees                 ExchangeFee?
  offers               ExchangeOffer[]
  affiliateClicks      AffiliateClick[]

  @@map("exchanges")
}

// ─── ExchangeFee ────────────────────────────────────────────────────────────────

model ExchangeFee {
  id               String   @id @default(cuid())
  exchangeId       String   @unique @map("exchange_id")
  spotMakerFee     Float    @default(0) @map("spot_maker_fee")
  spotTakerFee     Float    @default(0) @map("spot_taker_fee")
  futuresMakerFee  Float?   @map("futures_maker_fee")
  futuresTakerFee  Float?   @map("futures_taker_fee")
  withdrawalFee    Float?   @map("withdrawal_fee")
  updatedAt        DateTime @updatedAt @map("updated_at")

  exchange         Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@map("exchange_fees")
}

// ─── ExchangeOffer ──────────────────────────────────────────────────────────────

model ExchangeOffer {
  id           String    @id @default(cuid())
  exchangeId   String    @map("exchange_id")
  offerText    String    @map("offer_text")
  bonusAmount  Float?    @map("bonus_amount")
  expiresAt    DateTime? @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  exchange     Exchange  @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@map("exchange_offers")
}

// ─── AffiliateClick ─────────────────────────────────────────────────────────────

model AffiliateClick {
  id               String   @id @default(cuid())
  exchangeId       String   @map("exchange_id")
  exchangeSlug     String   @default("") @map("exchange_slug")
  sourcePage       String   @map("source_page")
  sourceType       String   @default("unknown") @map("source_type")
  sourcePath       String   @default("") @map("source_path")
  pageType         String?  @map("page_type")
  destinationUrl   String   @default("") @map("destination_url")
  campaignTag      String?  @map("campaign_tag")
  clickedAt        DateTime @default(now()) @map("clicked_at")
  ipHash           String   @map("ip_hash")
  userAgent        String?  @map("user_agent")
  referrer         String?  @map("referrer")
  country          String?  @map("country")

  // Revenue placeholders (for future conversion/revenue import)
  conversionCount  Int?     @map("conversion_count")
  estimatedRevenue Float?   @map("estimated_revenue")
  networkName      String?  @map("network_name")

  exchange         Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@index([exchangeSlug])
  @@index([sourceType])
  @@index([clickedAt])
  @@map("affiliate_clicks")
}

// ─── BlogPost ───────────────────────────────────────────────────────────────────

model BlogPost {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  content          String
  metaTitle        String?   @map("meta_title")
  metaDescription  String?   @map("meta_description")
  featuredImage    String?   @map("featured_image")
  category         String?
  tags             String[]  @default([])
  publishedAt      DateTime? @map("published_at")
  scheduledFor     DateTime? @map("scheduled_for")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("blog_posts")
}


// ─── NewsletterSubscriber ─────────────────────────────────────────────────────

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("newsletter_subscribers")
}
